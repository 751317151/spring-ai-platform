<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.huah.ai.platform.rag.mapper.KnowledgeBaseMapper">
    <select id="selectByStatus" resultType="com.huah.ai.platform.rag.model.KnowledgeBase">
        SELECT * FROM knowledge_bases WHERE status = #{status}
    </select>
    <select id="selectByDepartment" resultType="com.huah.ai.platform.rag.model.KnowledgeBase">
        SELECT * FROM knowledge_bases WHERE department = #{department}
    </select>
</mapper>
