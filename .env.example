# ===== Enterprise AI Platform 环境变量配置 =====
# 复制此文件为 .env，填入真实 API Key

# ======== AI 模型 API Keys ========
# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# DeepSeek（推荐，兼容 OpenAI 协议，性价比高）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# 通义千问（阿里云）
QWEN_API_KEY=sk-your-qwen-key-here

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ======== 安全 ========
# 至少 256 bit，随机字符串
JWT_SECRET=replace-this-with-a-very-long-random-secret-key-256bits

# ======== 数据库 ========
DB_USER=postgres
DB_PASS=your-postgres-password

# ======== 可选：对象存储（文档原始文件）========
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=your-access-key
# MINIO_SECRET_KEY=your-secret-key
# MINIO_BUCKET=enterprise-ai-docs
