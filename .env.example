# ============================================================
# Environment variables for Spring AI Platform
# Copy this file to .env and replace sample values as needed.
# ============================================================

# ======== LLM settings shared by agent-service / rag-service ========
ALI_QWEN_API_KEY=sk-your-qwen-api-key
DB_USER=postgres
DB_PASS=replace-with-db-password
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
LLM_MODEL=qwen3-vl-flash-2026-01-22

# ======== Gateway provider API keys ========
OPENAI_API_KEY=sk-xxx
DEEPSEEK_API_KEY=sk-xxx
QWEN_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# ======== Security ========
JWT_SECRET=replace-this-with-a-very-long-random-secret-key-256bits
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ======== S3 / MinIO storage for RAG files ========
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=blackstar
S3_REGION=us-east-1
APP_CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*,http://localhost,http://127.0.0.1

# ======== Optional tool API keys ========
TAVILY_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
QWEATHER_API_KEY=

# ======== Grafana ========
GRAFANA_PASSWORD=admin123

# ======== Optional retry / alertmanager ========
RAG_RETRY_FAILED_ENABLED=false
RAG_RETRY_FAILED_BATCH_SIZE=5
RAG_RETRY_FAILED_INITIAL_DELAY_MS=60000
RAG_RETRY_FAILED_FIXED_DELAY_MS=300000
ALERTMANAGER_ENABLED=false
ALERTMANAGER_BASE_URL=http://localhost:9093
ALERTMANAGER_UI_BASE_URL=http://localhost:9093
