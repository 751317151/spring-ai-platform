# ============================================================
# Enterprise AI Platform — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
# ============================================================

# ======== LLM 模型配置（agent-service / rag-service 共用）========
ALI_QWEN_API_KEY=sk-your-qwen-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
LLM_MODEL=qwen3-vl-plus-2025-12-19

# ======== Gateway 多模型 API Keys ========
OPENAI_API_KEY=sk-xxx
DEEPSEEK_API_KEY=sk-xxx
QWEN_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# ======== 安全 ========
JWT_SECRET=replace-this-with-a-very-long-random-secret-key-256bits

# ======== S3 / MinIO 存储（RAG 文档文件）========
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=blackstar
S3_REGION=us-east-1

# ======== Tool API Keys（可选，不配置则对应工具返回提示）========
TAVILY_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
QWEATHER_API_KEY=

# ======== Grafana ========
GRAFANA_PASSWORD=admin123
