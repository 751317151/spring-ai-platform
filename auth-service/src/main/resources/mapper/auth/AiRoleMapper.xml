<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.huah.ai.platform.auth.mapper.AiRoleMapper">
    <select id="selectByRoleNames" resultType="com.huah.ai.platform.auth.model.AiRoleEntity">
        SELECT id, role_name, description
        FROM ai_roles
        WHERE role_name IN
        <foreach collection="roleNames" item="roleName" open="(" separator="," close=")">
            #{roleName}
        </foreach>
        ORDER BY role_name ASC
    </select>
</mapper>
