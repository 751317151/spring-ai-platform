<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.huah.ai.platform.auth.mapper.BotPermissionMapper">
    <select id="selectByBotTypeAndEnabled" resultType="com.huah.ai.platform.auth.model.BotPermission">
        SELECT * FROM ai_bot_permissions
        WHERE bot_type = #{botType}
          AND enabled = true
    </select>
</mapper>
