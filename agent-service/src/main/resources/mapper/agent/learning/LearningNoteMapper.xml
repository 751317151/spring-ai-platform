<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.huah.ai.platform.agent.learning.LearningNoteMapper">
    <select id="selectByUserId" resultType="com.huah.ai.platform.agent.learning.LearningNoteEntity">
        SELECT * FROM learning_notes
        WHERE user_id = #{userId}
        ORDER BY updated_at DESC
    </select>
    <delete id="deleteByUserIdAndId">
        DELETE FROM learning_notes
        WHERE user_id = #{userId}
          AND id = #{id}
    </delete>
</mapper>
